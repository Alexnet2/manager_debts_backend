{
  "name": "decibel-meter-backend",
  "version": "1.0.0",
  "description": "Backend for extracting decibel metrics from video using 7-segment display detection",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "download-models": "ts-node -r tsconfig-paths/register scripts/download-models.ts"
  },
  "dependencies": {
    "axios": "^1.3.4",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "exceljs": "^4.3.0",
    "express": "^4.18.2",
    "express-fileupload": "^1.4.0",
    "fluent-ffmpeg": "^2.1.2",
    "onnxruntime-node": "^1.20.1",
    "sharp": "^0.33.0",
    "uuid": "^9.0.0"
  },
  "optionalDependencies": {
    "@u4/opencv4nodejs": "^6.3.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/express-fileupload": "^1.5.1",
    "@types/fluent-ffmpeg": "^2.1.6",
    "@types/jest": "^29.2.4",
    "@types/node": "^18.11.18",
    "@types/uuid": "^9.0.1",
    "jest": "^29.3.1",
    "ts-jest": "^29.0.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^4.9.4"
  }
}
