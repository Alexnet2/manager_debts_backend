NODE_ENV=development
PORT=3000
# Em produção (Vercel), defina como a URL real do frontend:
# FRONTEND_URL=https://reading-metrics-db.vercel.app
FRONTEND_URL=http://localhost:4200

# Upload settings
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=500000000
TEMP_DIR=./temp

# Video processing
VIDEO_FPS=30
VIDEO_FRAME_INTERVAL=2
VIDEO_SAMPLE_FPS=5
VIDEO_MAX_FRAMES=

# Image processing (crop dimensions calculated dynamically from video)
IMAGE_CROP_X=0
IMAGE_CROP_Y=0
IMAGE_CROP_WIDTH_PERCENT=1.0
IMAGE_CROP_HEIGHT_PERCENT=1.0
IMAGE_GRAYSCALE=true
IMAGE_CONTRAST=1.2
IMAGE_BRIGHTNESS=0
IMAGE_SHARPEN=true
IMAGE_THRESHOLD=128
IMAGE_RESIZE_SCALE=2

# OCR configuration
OCR_LANGUAGE=eng
OCR_WORKER_COUNT=4
TESSERACT_PATH=

# Validation settings
VALIDATION_MIN_VALUE=0
VALIDATION_MAX_VALUE=140
VALIDATION_SMOOTHING_THRESHOLD=5
VALIDATION_REMOVE_DUPLICATES=true

# Calibration
CALIBRATION_FILE=./data/calibration.json
